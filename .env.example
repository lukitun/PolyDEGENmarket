# Polymarket wallet private key (Polygon network)
# Create a new wallet, fund it with USDC on Polygon, paste the private key here
POLYMARKET_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Polymarket API (don't change unless you know what you're doing)
POLYMARKET_HOST=https://clob.polymarket.com
CHAIN_ID=137
SIGNATURE_TYPE=1
FUNDER=

# SOCKS5 proxy (optional — only needed if Polymarket is blocked in your region)
# Leave blank if you're in the US or an unblocked region
# Example: socks5://1.2.3.4:1080
SOCKS_PROXY=
